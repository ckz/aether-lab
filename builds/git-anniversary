#!/usr/bin/env bash
# git-anniversary — what were you coding on this day in previous years?
# Usage: git-anniversary [years_back]
# Example: git-anniversary 5
#          git-anniversary 1 3 10
#          git-anniversary  (default: 1, 3, 5 years)

set -uo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# Check we're in a git repo
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo -e "${RED}Not inside a git repository.${RESET}" >&2
    exit 1
fi

# Get today's date components
TODAY=$(date +%Y-%m-%d)
THIS_YEAR=$(date +%Y)
TODAY_MMDD=$(date +%m%d)

# Default years to look back
if [ $# -eq 0 ]; then
    YEARS=(1 3 5)
else
    YEARS=("$@")
fi

# Validate years
for y in "${YEARS[@]}"; do
    if ! [[ "$y" =~ ^[0-9]+$ ]] || [ "$y" -le 0 ]; then
        echo -e "${RED}Invalid year offset: ${y}${RESET}" >&2
        echo "Usage: git-anniversary [positive_year_offset ...]" >&2
        exit 1
    fi
done

# Get repo name for context
REPO_NAME=$(basename "$(git rev-parse --show-toplevel)")

echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════════╗${RESET}"
printf "${BOLD}${CYAN}║${RESET}  ${BOLD}📸  git-anniversary — ${REPO_NAME}${RESET}${CYAN}  ║${RESET}\n"
printf "${BOLD}${CYAN}║${RESET}  ${DIM}Today is ${TODAY} — here's what you shipped before${RESET}${CYAN}  ║${RESET}\n"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════════╝${RESET}"
echo ""

FOUND_ANY=false

for y in "${YEARS[@]}"; do
    PAST_YEAR=$((THIS_YEAR - y))
    DATE_STR="${PAST_YEAR}-${TODAY_MMDD:0:2}-${TODAY_MMDD:2:2}"
    SINCE="${PAST_YEAR}-01-01"
    UNTIL="${PAST_YEAR}-12-31 23:59:59"

    # Match commits on this exact calendar date in the past year
    COMMITS=$(git log --all --since="${SINCE}" --until="${UNTIL}" \
        --date=short --pretty=format:"%h|%an|%ad|%s" --numstat 2>/dev/null | \
        awk -v target="${TODAY_MMDD}" '
        BEGIN { RS = ""; output = ""; found = 0 }
        {
            lines = split($0, parts, "\n")
            split(parts[1], header, "|")
            gsub(/^ +| +$/, "", header[3])
            split(header[3], d, "-")
            mmdd = d[2] d[3]
            if (mmdd == target) {
                found = 1
                output = output "---COMMIT---\n"
                output = output header[1] "|" header[2] "|" header[3] "|" header[4] "\n"
                for (i = 2; i <= lines; i++) {
                    if (parts[i] ~ /^[0-9]+\t[0-9]+\t/) {
                        output = output parts[i] "\n"
                    }
                }
            }
        }
        END { printf "%s", output; if (!found) exit 1 }
    ') || true

    if [ -n "$COMMITS" ]; then
        FOUND_ANY=true
        COMMIT_COUNT=$(echo "$COMMITS" | grep -c '^---COMMIT---' || true)

        echo -e "${MAGENTA}${BOLD}  ┌─ ${y} year(s) ago · ${DATE_STR}${RESET}"
        echo -e "${DIM}  │  ${COMMIT_COUNT} commit(s) found${RESET}"
        echo -e "${MAGENTA}  │${RESET}"

        echo "$COMMITS" | awk -v red="$RED" -v green="$GREEN" -v yellow="$YELLOW" \
            -v cyan="$CYAN" -v magenta="$MAGENTA" -v bold="$BOLD" -v dim="$DIM" -v reset="$RESET" '
        BEGIN { first = 1 }
        {
            if ($0 == "---COMMIT---") {
                if (!first) {
                    print magenta "  │" reset
                    print magenta "  └────────────────────────────────────────────────────" reset
                    print magenta "  │" reset
                }
                first = 0
                next
            }

            # Parse commit header: hash|author|date|subject
            split($0, header, "|")
            hash = header[1]
            author = header[2]
            date_str = header[3]
            subj = header[4]
            gsub(/^ +| +$/, "", hash)
            gsub(/^ +| +$/, "", author)
            gsub(/^ +| +$/, "", date_str)
            gsub(/^ +| +$/, "", subj)

            if (length(subj) > 58) subj = substr(subj, 1, 55) "..."

            emoji = "📝"
            low = tolower(subj)
            if (low ~ /fix|bug|hotfix|patch/) emoji = "🔧"
            else if (low ~ /feat|add|new|implement/) emoji = "✨"
            else if (low ~ /refactor|clean|reorganize/) emoji = "🏗️ "
            else if (low ~ /merge|pull/) emoji = "🔀"
            else if (low ~ /test|spec/) emoji = "🧪"
            else if (low ~ /doc|readme|comment/) emoji = "📖"
            else if (low ~ /perf|optimize|speed/) emoji = "⚡"
            else if (low ~ /remove|delete|drop/) emoji = "🗑️ "
            else if (low ~ /style|css|theme|ui|ux/) emoji = "🎨"

            printf "  │  %s ${bold}%s${reset} ${dim}%s${reset}\n", emoji, hash, subj
            printf "  │    ${dim}by %s · %s${reset}\n", author, date_str
        }
        END {
            if (!first) {
                print magenta "  └────────────────────────────────────────────────────" reset
            }
        }
        '

        # Show file stats separately
        echo "$COMMITS" | awk '
        BEGIN { first = 1 }
        /^---COMMIT---/ { first = 1; next }
        NF == 0 { next }
        /^[0-9a-f]+\|/ { next }
        {
            split($0, f, "\t")
            if (length(f) >= 3 && f[1] ~ /^[0-9]+$/ && f[2] ~ /^[0-9]+$/) {
                added += f[1]
                deleted += f[2]
                count++
                names[count] = f[3]
            }
        }
        END {
            if (count > 0) {
                stats = ""
                if (added > 0) stats = "+" added
                if (deleted > 0) {
                    if (stats != "") stats = stats " "
                    stats = stats "-" deleted
                }
                if (count == 1)
                    printf "  │    %s%d file · %s%s\n", dim, count, stats, reset
                else
                    printf "  │    %s%d files · %s%s\n", dim, count, stats, reset

                show = (count < 4) ? count : 4
                for (i = 1; i <= show; i++) {
                    fname = names[i]
                    if (length(fname) > 45)
                        fname = "..." substr(fname, length(fname) - 42)
                    printf "  │    %s  %s%s\n", dim, fname, reset
                }
                if (count > 4)
                    printf "  │    %s  ... and %d more%s\n", dim, count - 4, reset
            }
        }
        '
        echo ""
    fi
done

# If nothing found at all
if [ "$FOUND_ANY" = false ]; then
    echo -e "${YELLOW}  No commits found on this date in previous years.${RESET}"
    echo -e "${DIM}  Either you were resting, or your git history is younger than these lookups.${RESET}"
    echo ""
fi

# Fun extra: overall git age
echo -e "${BOLD}${CYAN}  ── Context ──${RESET}"
FIRST_COMMIT=$(git log --all --reverse --date=short --pretty=format:"%ad" 2>/dev/null | head -1)
COMMIT_TOTAL=$(git rev-list --all --count 2>/dev/null || echo "?")
CONTRIBUTORS=$(git shortlog -sn --all 2>/dev/null | head -5 | awk '{print $2}' | tr '\n' ', ' | sed 's/,$//')

if [ -n "$FIRST_COMMIT" ]; then
    echo -e "  ${DIM}First commit:${RESET} ${FIRST_COMMIT}"
    echo -e "  ${DIM}Total commits:${RESET} ${COMMIT_TOTAL}"
    [ -n "$CONTRIBUTORS" ] && echo -e "  ${DIM}Contributors:${RESET} ${CONTRIBUTORS}"
fi

echo ""
echo -e "${DIM}  Run with custom years: git-anniversary 2 7 20${RESET}"
echo -e "${DIM}  Or set default in .bashrc: alias anniversary=\"git-anniversary\"${RESET}"
echo ""
